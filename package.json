{
  "name": "soa-harness-impl",
  "version": "0.0.0",
  "private": true,
  "description": "SOA-Harness v1.0 reference implementation — TypeScript monorepo (Core / Core+SI / Core+Handoff profiles).",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "test": "pnpm -r --filter=./packages/* test",
    "lint": "pnpm -r --filter=./packages/* lint",
    "typecheck": "pnpm -r --filter=./packages/* typecheck",
    "clean": "pnpm -r --filter=./packages/* clean"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.15.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
