{
  "name": "@soa-harness/core",
  "version": "1.1.0",
  "description": "SOA-Harness core primitives: JCS canonicalization (wrapper around the canonicalize npm package by Samuel Erdtman), digest helpers, tasks-fingerprint.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "canonicalize": "^3.0.0"
  }
}
