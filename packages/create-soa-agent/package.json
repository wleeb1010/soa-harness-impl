{
  "name": "create-soa-agent",
  "version": "1.0.0-rc.3",
  "description": "Bootstrap a new SOA-Harness agent repo with a working Runner, Agent Card, and example hook.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "files": [
    "dist",
    "templates"
  ],
  "bin": {
    "create-soa-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@peculiar/x509": "^2.0.0",
    "@soa-harness/core": "workspace:*",
    "@soa-harness/runner": "workspace:*",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@soa-harness/schemas": "workspace:*"
  }
}
