{
  "name": "@soa-harness/runner",
  "version": "0.0.0",
  "private": true,
  "description": "SOA-Harness Runner — HTTP surface, trust bootstrap, Agent Card, StreamEvents, permission resolver, attestation, audit, probes.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "soa-runner": "./dist/bin/start-runner.js"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "start": "node ./dist/bin/start-runner.js"
  },
  "dependencies": {
    "@peculiar/x509": "^2.0.0",
    "@soa-harness/core": "workspace:*",
    "@soa-harness/schemas": "workspace:*",
    "fastify": "^5.8.5",
    "jose": "^6.2.2",
    "reflect-metadata": "^0.2.2"
  }
}
