{
  "name": "@soa-harness/schemas",
  "version": "1.0.0-rc.0",
  "description": "Compiled Ajv validators for SOA-Harness schemas, generated from the pinned spec commit.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "files": ["dist"],
  "scripts": {
    "prebuild": "node scripts/build-validators.mjs",
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "codegen": "node scripts/build-validators.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
