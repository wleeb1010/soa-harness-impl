#!/usr/bin/env bash
# Refresh the CodeGraphContext index after every commit.
#
# Installed via `git config core.hooksPath scripts/hooks` — see
# scripts/cgc-setup.sh. Safe to run manually: `scripts/hooks/post-commit`.
#
# Runs the `cgc index` command in the background so the commit returns
# immediately; the index job takes a few seconds to a minute depending
# on the size of the change set. Output lands at logs/cgc-refresh.log
# for post-mortem.
#
# Prereq: `cgc` on PATH (user-level CodeGraphContext install).
# When cgc isn't installed the hook no-ops silently — keeps the hook
# safe to share across checkouts that may or may not have the tool.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

mkdir -p logs

if ! command -v cgc >/dev/null 2>&1 && [ ! -x "$HOME/AppData/Local/Programs/Python/Python312/Scripts/cgc.EXE" ]; then
  # No cgc installed — hook is a no-op. Exit 0 so the commit isn't
  # blocked by a missing optional dev tool.
  exit 0
fi

cgc_bin="cgc"
if ! command -v cgc >/dev/null 2>&1; then
  cgc_bin="$HOME/AppData/Local/Programs/Python/Python312/Scripts/cgc.EXE"
fi

# Force UTF-8 on Windows to dodge the cp1252 emoji-encoding bug.
PYTHONIOENCODING=utf-8 nohup "$cgc_bin" index . \
  > "$repo_root/logs/cgc-refresh.log" 2>&1 &
echo "[post-commit] cgc index refresh dispatched (pid $!)" >&2
